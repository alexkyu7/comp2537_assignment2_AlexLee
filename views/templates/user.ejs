<li>
    <div class="user-info">
        // Display username, email, and role badge
        <div class="username">
            <%= user.username %>
            <% if (user.user_type === "admin") { %>
                <span class="role-badge role-admin">Admin</span>
            <% } else { %>
                <span class="role-badge role-user">User</span>
            <% } %>
        </div>

        <div class="email"><%= user.email %></div>
        
        // Action buttons for promoting/demoting users
        <div class="actions">
            <% if (user.user_type === "admin") { %>
                <a href="/admin/demote/<%= user._id %>">Demote</a>
            <% } else { %>
                <a href="/admin/promote/<%= user._id %>">Promote</a>
            <% } %>
        </div>
    </div>
</li>