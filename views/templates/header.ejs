<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Common CSS -->
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/common.css">

    <!-- Page-specific CSS -->
    <% if (typeof cssFiles !== "undefined" && Array.isArray(cssFiles)) { %>
        <% cssFiles.forEach(file => { %>
            <link rel="stylesheet" href="/css/<%= file %>">
        <% }) %>
    <% } %>

    <!-- Favicon -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <title>
        <%= title %>
    </title>
</head>

<body>
    <div class="nav-background">
        <nav class="navbar">
            <ul class="nav-links">
                <li><a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>">Home</a></li>
                <li><a href="/login" class="<%= currentPage === 'login' ? 'active' : '' %>">Login</a></li>
                <li><a href="/signup" class="<%= currentPage === 'signup' ? 'active' : '' %>">Signup</a></li>
                <li><a href="/members" class="<%= currentPage === 'members' ? 'active' : '' %>">Members</a></li>
                <li><a href="/admin" class="<%= currentPage === 'admin' ? 'active' : '' %>">Admin</a></li>
            </ul>
        </nav>
    </div>